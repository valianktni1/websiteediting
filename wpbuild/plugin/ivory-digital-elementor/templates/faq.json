pe": "widget", "widgetType": "heading", "settings": {"title": "Your questions, answered.", "header_size": "h1", "align": "left", "title_color": "#2E332B", "typography_typography": "custom", "typography_font_family": "Cormorant Garamond", "typography_font_size": {"unit": "px", "size": 54, "sizes": []}, "typography_font_weight": "500", "typography_line_height": {"unit": "em", "size": 1.12, "sizes": []}, "_margin": {"unit": "px", "top": "0", "right": "0", "bottom": "10", "left": "0", "isLinked": false}}, "elements": []}, {"id": "fa08013", "elType": "widget", "widgetType": "divider", "settings": {"color": "#A78C46", "weight": {"unit": "px", "size": 1, "sizes": []}, "width": {"unit": "px", "size": 64, "sizes": []}, "align": "left", "gap": {"unit": "px", "size": 18, "sizes": []}, "_margin": {"unit": "px", "top": "16", "right": "0", "bottom": "16", "left": "0", "isLinked": false}}, "elements": []}], "isInner": true}], "isInner": false}, {"id": "e3b0ad5", "elType": "container", "settings": {"content_width": "full", "flex_direction": "column", "flex_align_items": "center", "background_background": "classic", "padding": {"unit": "px", "top": "78", "right": "20", "bottom": "78", "left": "20", "isLinked": false}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "background_color": "#ffffff"}, "elements": [{"id": "1074fd2", "elType": "container", "settings": {"content_width": "boxed", "flex_direction": "column", "flex_align_items": "flex-start", "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}, "boxed_width": {"unit": "px", "size": 820, "sizes": []}}, "elements": [{"id": "7592000", "elType": "widget", "widgetType": "accordion", "settings": {"tabs": [{"tab_title": "Do I own the booking system, or am I renting it?", "tab_content": "<p>You own it. Each system is privately built for your boutique and branded to you \u2014 it is not rented from a third-party booking platform. You simply have a simple hosting and maintenance package with us.</p>", "_id": "a92f270"}, {"tab_title": "Are there any per-booking fees or commissions?", "tab_content": "<p>No. You can take unlimited appointments without paying a commission on every booking. There are no third-party booking-platform subscriptions either.</p>", "_id": "e144842"}, {"tab_title": "How much does it cost?", "tab_content": "<p>Pricing is tailored to your boutique. In short, there is a one-off bespoke build and then a simple hosting and maintenance package. <a href=\"/contact/\">Contact us</a> for a clear, no-obligation quote.</p>", "_id": "272a8f9"}, {"tab_title": "Will it match my existing brand and website?", "tab_content": "<p>Yes. We style the booking system with your name, colours and photography so it feels like a seamless extension of your boutique. You can link to it from your website and Instagram.</p>", "_id": "070bb46"}, {"tab_title": "Can it handle more than one boutique?", "tab_content": "<p>Yes. The system supports multiple locations from a single control panel, each with its own opening hours, services, photos and booking questions.</p>", "_id": "d598eb1"}, {"tab_title": "Do my brides need to download an app?", "tab_content": "<p>No. It is a website, so it works instantly on any phone, tablet or computer with nothing to download.</p>", "_id": "f18a49f"}, {"tab_title": "How does it stop double-bookings?", "tab_content": "<p>A smart booking engine only ever offers times that are genuinely free, respecting your opening hours, how many appointments you can run at once, and the buffer you need between them \u2014 so two brides can never take the same slot.</p>", "_id": "5ee86a6"}, {"tab_title": "Can brides reschedule or cancel themselves?", "tab_content": "<p>Yes. Using their booking reference, brides can view, reschedule or cancel their own appointment with no phone calls, and can only move to times you actually have free.</p>", "_id": "51737c8"}, {"tab_title": "Do you host it and keep it backed up?", "tab_content": "<p>Yes. Our hosting and maintenance package includes reliable hosting on your domain, automatic nightly backups, updates and security patching, and friendly support.</p>", "_id": "eee4134"}, {"tab_title": "How do we get started?", "tab_content": "<p>Get in touch for a quote. We'll learn how your boutique runs, build and brand your system, set up your services and hours, and launch it for you.</p>", "_id": "9341655"}], "title_color": "#2E332B", "tab_active_color": "#A78C46", "content_color": "#79806E", "title_typography_typography": "custom", "title_typography_font_family": "Cormorant Garamond", "title_typography_font_size": {"unit": "px", "size": 20, "sizes": []}, "title_typography_font_weight": "500", "content_typography_typography": "custom", "content_typography_font_family": "Jost", "content_typography_font_size": {"unit": "px", "size": 15.5, "sizes": []}, "content_typography_font_weight": "400", "content_typography_line_height": {"unit": "em", "size": 1.7, "sizes": []}}, "elements": []}], "isInner": true}], "isInner": false}, {"id": "aeee1ae", "elType": "container", "settings": {"content_width": "full", "flex_direction": "column", "flex_align_items": "center", "background_background": "classic", "padding": {"unit": "px", "top": "70", "right": "20", "bottom": "70", "left": "20", "isLinked": false}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "background_color": "#8A9A7B"}, "elements": [{"id": "fecb7ba", "elType": "container", "settings": {"content_width": "boxed", "flex_direction": "column", "flex_align_items": "center", "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}, "boxed_width": {"unit": "px", "size": 640, "sizes": []}}, "elements": [{"id": "8066dcf", "elType": "widget", "widgetType": "heading", "settings":