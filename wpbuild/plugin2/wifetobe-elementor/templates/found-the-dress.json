, "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "dd14ee8", "elType": "widget", "widgetType": "html", "settings": {"html": "<section class=\"page-hero\"><div class=\"page-hero-bg\"><img alt=\"Bride at the mirror at Wife To Be\" decoding=\"async\" fetchpriority=\"high\" sizes=\"100vw\" src=\"https://images.unsplash.com/photo-1532454781337-fc3edff34f91?q=70&amp;w=1280&amp;auto=format&amp;fit=crop\" srcset=\"https://images.unsplash.com/photo-1532454781337-fc3edff34f91?q=70&amp;w=640&amp;auto=format&amp;fit=crop 640w, https://images.unsplash.com/photo-1532454781337-fc3edff34f91?q=70&amp;w=1280&amp;auto=format&amp;fit=crop 1280w, https://images.unsplash.com/photo-1532454781337-fc3edff34f91?q=70&amp;w=1920&amp;auto=format&amp;fit=crop 1920w\"/></div>\n<div class=\"container\"><span class=\"eyebrow\">The Experience</span><h1>No More Stress, I Found The Dress</h1><div class=\"breadcrumb\"><a href=\"/\">Home</a> \u00a0/\u00a0 Found The Dress</div></div>\n</section>"}, "elements": []}], "isInner": false}, {"id": "41360a3", "elType": "container", "settings": {"content_width": "full", "width": {"unit": "%", "size": 100, "sizes": []}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "10c699c", "elType": "widget", "widgetType": "html", "settings": {"html": "<section class=\"section\"><div class=\"container section-head reveal\">\n<span class=\"eyebrow\">Your Private Appointment</span><h2>Finding \u201cThe One\u201d, The Lovely Way</h2><span class=\"divider\"></span>\n<p class=\"lead\">Dress shopping should be one of the highlights of planning your wedding, not something you brace yourself for. We've spent years fine-tuning a calm, unhurried appointment so all you have to do is enjoy the moment your dress appears.</p>\n</div></section>"}, "elements": []}], "isInner": false}, {"id": "55004b4", "elType": "container", "settings": {"content_width": "full", "width": {"unit": "%", "size": 100, "sizes": []}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "e02f7ce", "elType": "widget", "widgetType": "html", "settings": {"html": "<section class=\"section band-ivory2\"><div class=\"container\">\n<div class=\"section-head reveal\"><span class=\"eyebrow\">How It Works</span><h2>What To Expect</h2><span class=\"divider\"></span></div>\n<div class=\"steps\">\n<div class=\"step reveal\"><h3>Book Privately</h3><p class=\"muted\">Reserve a dedicated slot and the boutique is entirely yours \u2014 no other brides, no clock ticking.</p></div>\n<div class=\"step reveal\"><h3>Tell Us About Your Day</h3><p class=\"muted\">Share your venue, your style and your budget. We listen carefully before we pull a single gown.</p></div>\n<div class=\"step reveal\"><h3>Try On Gowns</h3><p class=\"muted\">Explore the collection with your stylist \u2014 including a few surprises you'd never have chosen yourself.</p></div>\n<div class=\"step reveal\"><h3>Find The One</h3><p class=\"muted\">When it clicks, you'll simply know. From there we handle the fittings and alterations.</p></div>\n</div>\n</div></section>"}, "elements": []}], "isInner": false}, {"id": "ffda148", "elType": "container", "settings": {"content_width": "full", "width": {"unit": "%", "size": 100, "sizes": []}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "47c3727", "elType": "widget", "widgetType": "html", "settings": {"html": "<section class=\"section\"><div class=\"container split\">\n<div class=\"framed reveal\"><img alt=\"Delicate lace detail on a wedding dress\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1525169087805-031a4da0623c?q=80&amp;w=900&amp;auto=format&amp;fit=crop\"/></div>\n<div class=\"reveal\"><span class=\"eyebrow\">A Few Friendly Tips</span><h2>Make The Most Of Your Visit</h2><span class=\"divider left\"></span>\n<ul style=\"list-style:none;display:grid;gap:14px;margin:6px 0 24px\">\n<li><svg aria-hidden=\"true\" class=\"ico\" style=\"color:var(--gold);margin-right:12px\" viewbox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"></path></svg>Bring one or two people whose opinion you truly trust \u2014 too many voices can muddle things.</li>\n<li><svg aria-hidden=\"true\" class=\"ico\" style=\"color:var(--gold);margin-right:12px\" viewbox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"></path></svg>Wear nude, seamless underwear and pop any heels you're considering in your bag.</li>\n<li><svg aria-hidden=\"true\" class=\"ico\" style=\"color:var(--gold);margin-right:12px\" viewbox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"></path></svg>Stay open-minded \u2014 the gown you fall for is very often not the one you expected.</li>\n<li><svg aria-hidden=\"true\" class=\"ico\" style=\"color:var(--gold);margin-right:12px\" viewbox=\"0 0 24 24\"><path d=\"M20 6 9 17l-5-5\"></path></svg>Give yourself plenty of time so the whole thing stays relaxed and fun.</li>\n</ul>\n<a class=\"btn btn-gold\" data-testid=\"found-book\" href=\"mailto:thegroupuk@yahoo.com?subject=Appointment%20Request\">Book Your Appointment</a>\n</div>\n</div></section>"}, "elements": []}], "isInner": false}, {"id": "a7c5849", "elType": "container", "settings": {"content_width": "full", "width": {"unit": "%", "size": 100, "sizes": []}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "9c0dcbf", "elType": "widget", "widgetType": "html", "settings": {"html": "<section class=\"cta\"><div class=\"cta-bg\"><img alt=\"Bride in an elegant gown\" decoding=\"async\" loading=\"lazy\" sizes=\"100vw\" src=\"https://images.unsplash.com/photo-1492175742197-ed20dc5a6bed?q=70&amp;w=1280&amp;auto=format&amp;fit=crop\" srcset=\"https://images.unsplash.com/photo-1492175742197-ed20dc5a6bed?q=70&amp;w=640&amp;auto=format&amp;fit=crop 640w, https://images.unsplash.com/photo-1492175742197-ed20dc5a6bed?q=70&amp;w=1280&amp;auto=format&amp;fit=crop 1280w, https://images.unsplash.com/photo-1492175742197-ed20dc5a6bed?q=70&amp;w=1920&amp;auto=format&amp;fit=crop 1920w\"/></div>\n<div class=\"container\"><span class=\"eyebrow\" style=\"color:var(--champagne)\">It's Time</span><h2>Let's Find Your Dress</h2><p>Your gown is waiting somewhere on our rails. Book a relaxed, private appointment and come and meet it.</p><a class=\"btn btn-gold\" data-testid=\"cta-book\" href=\"mailto:thegroupuk@yahoo.com?subject=Appointment%20Request\">Book Appointment</a></div>\n</section>"}, "elements": []}], "isInner": false}, {"id": "6edeb22", "elType": "container", "settings": {"content_width": "full", "width": {"unit": "%", "size": 100, "sizes": []}, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "flex_gap": {"unit": "px", "size": 0, "sizes": [], "column": "0", "row": "0"}, "flex_direction": "column"}, "elements": [{"id": "fe78d91", "elType": "widget", "widgetType": "html", "settings": {"html": "<footer class=\"site-footer\"><